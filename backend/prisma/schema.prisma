generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum NivelPermissao {
  ADMINISTRADOR
  ENGENHEIRO
  OPERADOR
}

enum TipoAeronave {
  COMERCIAL
  MILITAR
}

enum TipoPeca {
  NACIONAL
  IMPORTADA
}

enum StatusPeca {
  EM_PRODUCAO
  EM_TRANSPORTE
  PRONTA
}

enum StatusEtapa {
  PENDENTE
  ANDAMENTO
  CONCLUIDA
}

enum TipoTeste {
  ELETRICO
  HIDRAULICO
  AERODINAMICO
}

enum ResultadoTeste {
  APROVADO
  REPROVADO
}

// ─── MODELS ──────────────────────────────────────────────────────────────────

model Funcionario {
  id             String         @id @db.VarChar(50)
  nome           String         @db.VarChar(150)
  telefone       String         @db.VarChar(30)
  endereco       String         @db.VarChar(300)
  usuario        String         @unique @db.VarChar(100)
  senha          String         @db.VarChar(255)
  nivelPermissao NivelPermissao @default(OPERADOR)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  etapas EtapaFuncionario[]

  @@map("funcionarios")
}

model Aeronave {
  id         Int          @id @default(autoincrement())
  codigo     String       @unique @db.VarChar(30)
  modelo     String       @db.VarChar(100)
  tipo       TipoAeronave @default(COMERCIAL)
  capacidade Int          @default(0)
  alcance    Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  pecas  Peca[]
  testes Teste[]
  etapas Etapa[]

  @@map("aeronaves")
}

model Peca {
  id         Int        @id @default(autoincrement())
  nome       String     @db.VarChar(150)
  tipo       TipoPeca   @default(NACIONAL)
  fornecedor String     @db.VarChar(150)
  status     StatusPeca @default(EM_PRODUCAO)
  aeronaveId Int
  aeronave   Aeronave   @relation(fields: [aeronaveId], references: [id], onDelete: Cascade)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("pecas")
}

model Etapa {
  id         Int         @id @default(autoincrement())
  nome       String      @db.VarChar(150)
  prazo      String      @db.VarChar(20)
  status     StatusEtapa @default(PENDENTE)
  aeronaveId Int
  aeronave   Aeronave    @relation(fields: [aeronaveId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  funcionarios EtapaFuncionario[]

  @@map("etapas")
}

model EtapaFuncionario {
  etapaId       Int
  funcionarioId String
  etapa         Etapa       @relation(fields: [etapaId], references: [id], onDelete: Cascade)
  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)

  @@id([etapaId, funcionarioId])
  @@map("etapa_funcionarios")
}

model Teste {
  id         Int            @id @default(autoincrement())
  tipo       TipoTeste      @default(ELETRICO)
  resultado  ResultadoTeste @default(APROVADO)
  aeronaveId Int
  aeronave   Aeronave       @relation(fields: [aeronaveId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@map("testes")
}
