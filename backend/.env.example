# ─── Banco de Dados ───────────────────────────────────────────────────────────
# Substitua user, password, host e dbname pelos seus dados do MySQL
DATABASE_URL="mysql://user:password@localhost:3306/aerocode"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="aerocode_secret_key_troque_em_producao"
JWT_EXPIRES_IN="8h"

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
